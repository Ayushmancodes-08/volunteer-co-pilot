# GenAI Provider (supports Gemini, Anthropic, and OpenAI)
# Set one of these API keys:
GEMINI_API_KEY=your_gemini_api_key_here
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Which provider to use: "gemini" (default), "anthropic", or "openai"
GENAI_PROVIDER=gemini

# Model names (optional, defaults below are used if unset)
GEMINI_MODEL=gemini-2.0-flash
ANTHROPIC_MODEL=claude-3-haiku-20240307
OPENAI_MODEL=gpt-4o-mini

# Server
PORT=4000
HOST=0.0.0.0

# CORS origin (deployed frontend URL)
CORS_ORIGIN=http://localhost:3000

# Cache TTL in seconds
CACHE_TTL=300
